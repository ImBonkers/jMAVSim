{
  "name": "basic_flight_test",
  "description": "Validate basic flight operations including arm, takeoff, hover, goto, and land",
  "globalTimeoutSeconds": 180,
  "steps": [
    { "type": "wait", "durationSeconds": 10 },
    { "type": "arm", "timeoutSeconds": 30 },
    { "type": "takeoff", "altitude": 5.0, "tolerance": 0.5, "timeoutSeconds": 30 },
    { "type": "hover", "durationSeconds": 5, "maxDrift": 0.3, "timeoutSeconds": 15 },
    { "type": "goto", "x": 10, "y": 0, "z": -5, "tolerance": 1.0, "timeoutSeconds": 45 },
    { "type": "setWind", "x": 3, "y": 0, "z": 0 },
    { "type": "hover", "durationSeconds": 5, "maxDrift": 0.5, "timeoutSeconds": 15 },
    { "type": "land", "timeoutSeconds": 30 },
    { "type": "disarm", "timeoutSeconds": 10 }
  ]
}
